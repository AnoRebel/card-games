# Card Games — environment variables
#
# The app runs with ZERO required secrets: gameplay state lives in the browser
# (IndexedDB) and online rooms use the Nitro-native WebSocket server. The vars
# below are optional tuning knobs plus the Railpack build settings used in
# production (Dokploy).

# --- Runtime ---------------------------------------------------------------
NODE_ENV=production
# Nitro listens here; Dokploy/Traefik proxies the public domain to this port.
NITRO_PORT=3000
HOST=0.0.0.0

# Force the Nitro-native WebSocket carrier (Conduit WebRTC is an optional, off-
# by-default enhancement). 'auto' | 'webrtc' | 'websocket'.
NUXT_PUBLIC_CONDUIT_TRANSPORT=websocket

# --- Analytics (self-hosted, privacy-friendly) -----------------------------
# Both are no-ops until a site id is set, so dev/local doesn't phone home.
# Umami → https://umami.anorebel.net  ·  Rybbit → https://rybbit.anorebel.net
NUXT_UMAMI_SITE_ID=
NUXT_RYBBIT_SITE_ID=

# --- Conduit (optional WebRTC P2P signaling; OFF by default) ---------------
# NUXT_CONDUIT_ENABLED=false
# NUXT_CONDUIT_AUTH_MODE=none          # 'none' | 'key'
# NUXT_CONDUIT_KEY=conduit             # required when auth mode is 'key'
# Comma-separated allowed origins for the relay (empty = allow all, dev only).
# NUXT_CONDUIT_ALLOWED_ORIGINS=https://card-games.anorebel.net

# --- Railpack build (Bun) — used by the Dokploy builder --------------------
# RAILPACK_PACKAGES=bun@latest
# RAILPACK_INSTALL_CMD=bun install
# RAILPACK_BUILD_CMD=bun run build
# RAILPACK_START_CMD=node .output/server/index.mjs
